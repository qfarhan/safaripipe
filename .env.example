# Copy to `.env` to control which compose files `docker compose` loads.
#   cp .env.example .env
#
# Docker Compose reads COMPOSE_FILE automatically, so once `.env` exists you just
# run `docker compose up -d` and get whichever stack you selected below.

# ---- Kerberos OFF (default: plaintext Kafka) ----
COMPOSE_FILE=docker-compose.yml

# ---- Kerberos ON (SASL/GSSAPI Kafka + KDC) ----
# Comment the line above and uncomment the line below, then `docker compose up -d`.
# On macOS/Linux the path separator is ":" (on native Windows it is ";").
#COMPOSE_FILE=docker-compose.yml:docker-compose.kerberos.yml
